---
import RouteLayout from './route.astro';

interface Props {
  title?: string;
  bodyClass?: string;
}

const {
  title = 'Climbing Guide',
  bodyClass = 'font-sans bg-base-100-content text-base-100',
} = Astro.props;
---

<RouteLayout
  title={title}
  bodyClass={bodyClass}
  containerClass="mx-auto space-y-4 relative md:max-w-6xl"
>
  <slot />
</RouteLayout>
