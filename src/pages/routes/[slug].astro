---
import { getEntry, render } from 'astro:content';
import RoutePage from '../../components/route-page.astro';

export async function getStaticPaths() {
  const { getCollection } = await import('astro:content');
  const routes = await getCollection('routes');

  return routes.map((route) => ({
    params: { slug: route.id },
  }));
}

const { slug } = Astro.params;

if (!slug) {
  throw new Error('Missing route slug.');
}

const route = await getEntry('routes', slug);

if (!route) {
  throw new Error(`Route not found for slug: ${slug}`);
}

const { Content } = await render(route);
---

<RoutePage
    area={route.data.area}
    route={route.data.route}
    rating={route.data.rating}
    Content={Content}
/>
